# Amazon Creators API
AMAZON_CREDENTIAL_ID=your_credential_id_here
AMAZON_CREDENTIAL_SECRET=your_credential_secret_here
AMAZON_ASSOCIATE_TAG=cnshophelper-20
AMAZON_COUNTRY=US

# Redis (auto-injected by Railway when you add the Redis plugin)
REDIS_URL=redis://localhost:6379

# App config
APP_ENV=development
AMAZON_MOCK=true
LOG_LEVEL=debug

# Optional (Phase 6+)
TRANSLATION_API_KEY=
